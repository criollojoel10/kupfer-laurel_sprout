_mode=cross
pkgname=firmware-sdm670-xiaomi-laurel
pkgver=23.0
pkgrel=1
_arches=specific
arch=(aarch64)
license=(custom:Proprietary)
options=(!strip)

source=(
    firmware/
    image/
)

sha256sums=(
    SKIP
    SKIP
)

package() {
    mkdir -p "$pkgdir"/lib/firmware/qcom/sdm670/laurel
    
    cp -r "$srcdir"/firmware/* "$pkgdir"/lib/firmware/qcom/sdm670/laurel/ 2>/dev/null || true
    cp -r "$srcdir"/image/* "$pkgdir"/lib/firmware/qcom/sdm670/laurel/ 2>/dev/null || true
    
    install -Dm644 "$srcdir"/../firmware-manifest.txt \
        "$pkgdir"/usr/share/doc/$pkgname/FIRMWARE_NOTES.txt
}